import os
for dirname, _, filenames in os.walk('/kaggle/input'):
    for filename in filenames:
        print(os.path.join(dirname, filename))

# 1. Imports
import numpy as np
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import sklearn
from sklearn.model_selection import train_test_split, GridSearchCV, cross_val_score
from sklearn.metrics import accuracy_score, classification_report, mean_absolute_error
from sklearn.ensemble import RandomForestClassifier, RandomForestRegressor, VotingClassifier
from sklearn.preprocessing import StandardScaler
from imblearn.over_sampling import SMOTE
from xgboost import XGBClassifier
import re

# Verify versions
print("numpy version:", np.__version__)
print("pandas version:", pd.__version__)
print("scikit-learn version:", sklearn.__version__)

# 2. Load Data
try:
    train = pd.read_csv('/kaggle/input/titanic/train.csv')
    test = pd.read_csv('/kaggle/input/titanic/test.csv')
except FileNotFoundError:
    print("Error: Dataset files not found. Please check the file paths.")
    exit()
# Print column names for debugging
print("Training data columns:", train.columns.tolist())
print("Test data columns:", test.columns.tolist())

# Preprocessing and Feature Engineering Function
def preprocess_data(df, train_data=None):
    # Extract Title from Name
    df['Title'] = df['Name'].apply(lambda x: re.search(' ([A-Za-z]+)\.', x).group(1))
    df['Title'] = df['Title'].replace(['Lady', 'Countess', 'Capt', 'Col', 'Don', 'Dr', 
                                      'Major', 'Rev', 'Sir', 'Jonkheer', 'Dona'], 'Rare')
    df['Title'] = df['Title'].replace(['Mlle', 'Ms'], 'Miss')
    df['Title'] = df['Title'].replace('Mme', 'Mrs')

    # Extract Deck from Cabin
    df['Deck'] = df['Cabin'].str[0].fillna('Unknown')

    # Create FamilySize and IsAlone
    df['FamilySize'] = df['SibSp'] + df['Parch'] + 1
    df['IsAlone'] = (df['FamilySize'] == 1).astype(int)

    # Create IsChild and PriorityScore
    df['IsChild'] = (df['Age'] < 12).astype(int) if 'Age' in df else 0
    df['PriorityScore'] = 0
    df.loc[(df['Sex'] == 'female') | (df['IsChild'] == 1), 'PriorityScore'] = 1

    # Bin Fare
    df['Fare'] = df['Fare'].fillna(train_data['Fare'].median() if train_data is not None else df['Fare'].median())
    df['FareBin'] = pd.qcut(df['Fare'], 4, labels=['Low', 'MidLow', 'MidHigh', 'High'])

    # Handle missing Embarked
    df['Embarked'] = df['Embarked'].fillna(train_data['Embarked'].mode()[0] if train_data is not None else df['Embarked'].mode()[0])

    # Drop irrelevant columns
    columns_to_drop = ['Cabin', 'Ticket', 'Name']
    existing_columns = [col for col in columns_to_drop if col in df.columns]
    if existing_columns:
        df = df.drop(existing_columns, axis=1)
    
    return df
# Predict missing Age with RandomForestRegressor
age_features = ['Pclass', 'Sex', 'SibSp', 'Parch', 'Fare', 'Embarked', 'FamilySize', 'IsChild', 'PriorityScore', 'Title', 'Deck']
train_age = preprocess_data(train.copy(), train_data=train)
X_age = pd.get_dummies(train_age[age_features], columns=['Sex', 'Embarked', 'Title', 'Deck'], drop_first=True)
y_age = train['Age']

valid_age_indices = ~y_age.isna()
X_age_train = X_age[valid_age_indices]
y_age_train = y_age[valid_age_indices]

scaler_age = StandardScaler()
X_age_train = scaler_age.fit_transform(X_age_train)

age_model = RandomForestRegressor(n_estimators=100, max_depth=7, random_state=1)
age_model.fit(X_age_train, y_age_train)

missing_age_indices = y_age.isna()
if missing_age_indices.any():
    X_age_missing = X_age[missing_age_indices]
    X_age_missing = scaler_age.transform(X_age_missing)
    train_age.loc[missing_age_indices, 'Age'] = age_model.predict(X_age_missing)

# Bin Age after prediction
train_age['AgeBin'] = pd.cut(train_age['Age'], bins=[0, 12, 20, 40, 60, 100], 
                             labels=['Child', 'Teen', 'Adult', 'MiddleAge', 'Senior'])

# Predict missing Age for test set
test_age = preprocess_data(test.copy(), train_data=train)
X_test_age = pd.get_dummies(test_age[age_features], columns=['Sex', 'Embarked', 'Title', 'Deck'], drop_first=True)
X_test_age = X_test_age.reindex(columns=X_age.columns, fill_value=0)
X_test_age = scaler_age.transform(X_test_age)
test_age['Age'] = age_model.predict(X_test_age)
test_age['AgeBin'] = pd.cut(test_age['Age'], bins=[0, 12, 20, 40, 60, 100], 
                            labels=['Child', 'Teen', 'Adult', 'MiddleAge', 'Senior'])

# Prepare final dataset
features = ['Pclass', 'Age', 'SibSp', 'Parch', 'Fare', 'FamilySize', 'IsChild', 'IsAlone', 
            'PriorityScore', 'Sex', 'Embarked', 'Title', 'Deck', 'AgeBin', 'FareBin']
train = train_age.copy()
test = test_age.copy()

X = pd.get_dummies(train[features], columns=['Sex', 'Embarked', 'Title', 'Deck', 'AgeBin', 'FareBin'], drop_first=True)
y = train['Survived']
X_test = pd.get_dummies(test[features], columns=['Sex', 'Embarked', 'Title', 'Deck', 'AgeBin', 'FareBin'], drop_first=True)
X, X_test = X.align(X_test, join='left', axis=1, fill_value=0)

# Feature selection based on importance (optional, based on initial Random Forest run)
scaler = StandardScaler()
X = scaler.fit_transform(X)
X_test = scaler.transform(X_test)

X_train, X_val, y_train, y_val = train_test_split(X, y, test_size=0.2, random_state=1)

# Handle imbalance with SMOTE
smote = SMOTE(sampling_strategy=0.8, random_state=1)
X_train_smote, y_train_smote = smote.fit_resample(X_train, y_train)

# Random Forest GridSearchCV
param_grid_rf = {
    'n_estimators': [100, 200],
    'max_depth': [5, 7],
    'min_samples_split': [2, 5],
    'max_leaf_nodes': [50, 100, 500]
}
rf_model = RandomForestClassifier(random_state=1)
grid_search_rf = GridSearchCV(rf_model, param_grid_rf, cv=5, scoring='accuracy', n_jobs=-1)
grid_search_rf.fit(X_train_smote, y_train_smote)
best_rf = grid_search_rf.best_estimator_

print("Best RF Parameters:", grid_search_rf.best_params_)
print("Best RF CV Accuracy:", grid_search_rf.best_score_)

# XGBoost GridSearchCV
param_grid_xgb = {
    'n_estimators': [100, 200],
    'max_depth': [3, 5, 7],
    'learning_rate': [0.01, 0.1],
    'subsample': [0.8, 1.0]
}
xgb_model = XGBClassifier(use_label_encoder=False, eval_metric='logloss', random_state=1)
grid_search_xgb = GridSearchCV(xgb_model, param_grid_xgb, cv=5, scoring='accuracy', n_jobs=-1)
grid_search_xgb.fit(X_train_smote, y_train_smote)
best_xgb = grid_search_xgb.best_estimator_

print("Best XGBoost Parameters:", grid_search_xgb.best_params_)
print("Best XGBoost CV Accuracy:", grid_search_xgb.best_score_)

# Ensemble Model (VotingClassifier)
ensemble_model = VotingClassifier(
    estimators=[('rf', best_rf), ('xgb', best_xgb)],
    voting='soft'
)
ensemble_model.fit(X_train_smote, y_train_smote)

# Evaluate Models
# Random Forest
y_val_pred_rf = best_rf.predict(X_val)
rf_val_acc = accuracy_score(y_val, y_val_pred_rf)
print("RF Validation Accuracy:", rf_val_acc)
print("RF Classification Report:\n", classification_report(y_val, y_val_pred_rf))

# XGBoost
y_val_pred_xgb = best_xgb.predict(X_val)
xgb_val_acc = accuracy_score(y_val, y_val_pred_xgb)
print("XGBoost Validation Accuracy:", xgb_val_acc)
print("XGBoost Classification Report:\n", classification_report(y_val, y_val_pred_xgb))

# Ensemble
y_val_pred_ensemble = ensemble_model.predict(X_val)
ensemble_val_acc = accuracy_score(y_val, y_val_pred_ensemble)
print("Ensemble Validation Accuracy:", ensemble_val_acc)
print("Ensemble Classification Report:\n", classification_report(y_val, y_val_pred_ensemble))

# Compare Models
plt.figure(figsize=(6, 4))
sns.barplot(x=['Random Forest', 'XGBoost', 'Ensemble'], y=[rf_val_acc, xgb_val_acc, ensemble_val_acc])
plt.title('Validation Accuracy Comparison')
plt.ylim(0.7, 0.9)
plt.ylabel('Accuracy')
plt.show()

# Cross-Validation on Full Dataset
cv_scores = cross_val_score(ensemble_model, X, y, cv=5, scoring='accuracy')
print("Ensemble CV Scores:", cv_scores)
